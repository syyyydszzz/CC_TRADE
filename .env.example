# =============================================================================
# QC MCP Strategy Workspace Environment Variables
# =============================================================================

# Anthropic API key for Claude Code and related tooling
ANTHROPIC_API_KEY=sk-ant-...

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# This repository does not manage QuantConnect credentials, brokerage secrets,
# or local Lean execution through `.env`.
#
# Execution is handled exclusively through `qc-mcp`, which is configured in
# Claude Code's user-level `~/.claude.json` and authenticated through the
# official QuantConnect Local Platform flow.
