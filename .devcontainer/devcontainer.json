{
    "name": "QC MCP Strategy Workspace",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "workspaceFolder": "/workspaces/qc-mcp-strategy-workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/qc-mcp-strategy-workspace,type=bind,consistency=cached",
    // If Claude Code runs inside the container and qc-mcp runs on the host,
    // you may need to uncomment the following line on Linux:
    // "runArgs": ["--add-host=host.docker.internal:host-gateway"],
    "containerEnv": {
        "PYTHONPATH": "/workspaces/qc-mcp-strategy-workspace/algorithms",
        "PYTHONDONTWRITEBYTECODE": "1",
        "CLAUDE_CONFIG_DIR": "/root/.claude"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.formatting.provider": "black",
                "python.formatting.blackPath": "/usr/local/bin/black",
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "explicit"
                },
                "terminal.integrated.defaultProfile.linux": "zsh",
                "python.analysis.extraPaths": [
                    "/workspaces/qc-mcp-strategy-workspace/algorithms"
                ],
                "python.envFile": "${workspaceFolder}/.env",
                "task.allowAutomaticTasks": "on"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "anthropic.claude-code",
                "github.vscode-github-actions",
                "bierner.markdown-mermaid"
            ]
        }
    },
    "remoteUser": "root",
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind",
        // Optional:
        // "source=${localEnv:HOME}/.claude.json,target=/root/.claude.json,type=bind"
    ],
    "postCreateCommand": "mkdir -p algorithms docs results",
    "overrideCommand": false,
    "remoteEnv": {
        "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
    }
}
